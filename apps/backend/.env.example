# Copy to `.env` or `.env.local` and replace placeholders. Never commit real secrets.

# -----------------------------------------------------------------------------
# Local database: the "Local dev defaults" block below is active. Uncomment this
# section and comment out the duplicate SPRING_DATASOURCE_* lines in that block
# to use DigitalOcean Postgres instead of local Docker.
# -----------------------------------------------------------------------------

# Spring Datasource (DigitalOcean — example placeholders only)
#SPRING_DATASOURCE_PASSWORD=AVNS_example_fake_password_string_here
#SPRING_DATASOURCE_URL=jdbc:postgresql://db.example.ondigitalocean.com:25061/DevPool?sslmode=require
#SPRING_DATASOURCE_USERNAME=doadmin

# -----------------------------------------------------------------------------
# DigitalOcean Spaces (images)
# -----------------------------------------------------------------------------
DO_SPACES_ENDPOINT=https://tor1.digitaloceanspaces.com
DO_SPACES_BUCKET=your-spaces-bucket-name
DO_SPACES_KEY=DO00EXAMPLEFAKEACCESSKEYID00
DO_SPACES_SECRET=your_spaces_secret_access_key_placeholder
DO_SPACES_BASE_URL=https://your-bucket-name.tor1.cdn.digital oceanspaces.com
DO_SPACES_PREFIX=customers

# -----------------------------------------------------------------------------
# Local dev defaults (dockerized Postgres + Valkey)
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/peelin
SPRING_DATASOURCE_USERNAME=baker
SPRING_DATASOURCE_PASSWORD=Password1
SPRING_DATA_REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Stripe (payments)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY

# -----------------------------------------------------------------------------
# OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret_placeholder

MICROSOFT_CLIENT_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_CLIENT_SECRET=replace_with_microsoft_client_secret_value

# -----------------------------------------------------------------------------
# AI (OpenRouter)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY

# -----------------------------------------------------------------------------
# Mail
# -----------------------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=you@example.com
MAIL_PASSWORD=your_app_specific_password_placeholder
MAIL_FROM=you@example.com

# -----------------------------------------------------------------------------
# JWT (required — generate e.g. openssl rand -hex 32)
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_generate_a_long_random_secret_at_least_32_bytes

# -----------------------------------------------------------------------------
# Optional: observability / cache SaaS (uncomment if you use them)
# -----------------------------------------------------------------------------
#UPSTASH_REDIS_REST_URL=rediss://default:YOUR_TOKEN@YOUR_HOST:6380
#UPSTASH_REDIS_TOKEN=YOUR_UPSTASH_REDIS_TOKEN
#UPSTASH_REDIS_URL=redis://default:YOUR_TOKEN@YOUR_HOST:6379
#SENTRY_AUTH_TOKEN=YOUR_SENTRY_AUTH_TOKEN
