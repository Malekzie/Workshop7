DO_SPACES_ENDPOINT=https://tor1.digitaloceanspaces.com
DO_SPACES_BUCKET=peelin-good-storage
DO_SPACES_KEY=YOUR_SPACES_ACCESS_KEY_ID
DO_SPACES_SECRET=YOUR_SPACES_SECRET_ACCESS_KEY
DO_SPACES_BASE_URL=https://peelin-good-storage.tor1.cdn.digitaloceanspaces.com
DO_SPACES_PREFIX=customers

# Local dev defaults (dockerized Postgres + Valkey)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/peelin
SPRING_DATASOURCE_USERNAME=baker
SPRING_DATASOURCE_PASSWORD=Password1
SPRING_DATA_REDIS_URL=redis://localhost:6379

# Cloud Redis (optional override)
UPSTASH_REDIS_REST_URL=rediss://default:YOUR_UPSTASH_REDIS_TOKEN@YOUR_UPSTASH_HOST:6380
UPSTASH_REDIS_TOKEN=YOUR_UPSTASH_REDIS_TOKEN
UPSTASH_REDIS_URL=redis://default:YOUR_UPSTASH_REDIS_TOKEN@YOUR_UPSTASH_HOST:6379
SENTRY_AUTH_TOKEN=YOUR_SENTRY_AUTH_TOKEN