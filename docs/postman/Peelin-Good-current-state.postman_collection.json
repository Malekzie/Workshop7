          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "photo", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/account/profile-photo",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "account", "profile-photo"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Upload status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json && json.id) pm.collectionVariables.set('customerId', json.id);",
                  "if (json && typeof json.photoApprovalPending !== 'undefined') pm.collectionVariables.set('photoApprovalPending', String(json.photoApprovalPending));",
                  "if (json && json.profilePhotoPath) pm.collectionVariables.set('uploadedProfilePhotoPath', json.profilePhotoPath);"
                ]
              }
            }
          ]
        }
      ]
